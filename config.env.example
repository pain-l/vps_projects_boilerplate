# vps_projects_boilerplate — bootstrap configuration
#
# Copy this file to  config.env  and edit it, then run  sudo ./bootstrap.sh
#   cp config.env.example config.env
#
# Only ADMIN_SSH_PUBKEY is mandatory. Everything else has a sane default.

# REQUIRED — the OpenSSH PUBLIC key you will use to log in. It is installed for
# both root (admin) and the deploy user (git push). SSH hardening disables
# password login, so this MUST be a key you actually hold, or you lock yourself
# out. Paste the full single line (contents of e.g. ~/.ssh/id_ed25519.pub).
ADMIN_SSH_PUBKEY=""

# SSH port. Leave 22 unless you have a reason. If you change it, the firewall
# and the hardening drop-in are updated to match.
SSH_PORT="22"

# IANA timezone for the box (e.g. UTC, Europe/Brussels, America/New_York).
TIMEZONE="UTC"

# Install the Bun runtime for the deploy user. Bun is the default fallback
# runtime (run -> `bun server.ts`, build -> `bun install`). Set to false if
# you'll only run other languages.
INSTALL_BUN="true"

# Disable SSH password login (key-only). Strongly recommended. The script
# refuses to do this unless ADMIN_SSH_PUBKEY is installed first.
HARDEN_SSH="true"

# UFW firewall: allow only SSH + 80/443 inbound, deny the rest.
ENABLE_FIREWALL="true"

# fail2ban: ban hosts that brute-force SSH.
ENABLE_FAIL2BAN="true"

# Automatic unattended security upgrades.
ENABLE_UNATTENDED_UPGRADES="true"

# Optional email for unattended-upgrades notifications (needs a working MTA).
ADMIN_EMAIL=""
